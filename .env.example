# BioAro frontend runtime configuration
# Copy this file to .env.local for local development.

# Shopify Storefront API
VITE_SHOPIFY_DOMAIN=your-store.myshopify.com
VITE_SHOPIFY_STOREFRONT_TOKEN=your_public_storefront_token

# Optional: keep preview catalog/cart fallback enabled.
# Set to "false" once Shopify products, carts, and market pricing are ready.
VITE_SHOPIFY_USE_MOCK_DATA=true

# Optional: external Geo-IP/bootstrap endpoint.
# Expected JSON shape:
# {
#   "country": "US" | "CA" | "GB",
#   "currency": "USD" | "CAD" | "GBP",
#   "experienceRegion": "NA" | "UK"
# }
VITE_MARKET_BOOTSTRAP_URL=
